# ─── DATABASE ───────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/nasreen-crafts

# ─── JWT ────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# ─── RAZORPAY ───────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ─── RESEND (Email) ─────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@Royce Lighting.com
ADMIN_EMAIL=admin@Royce Lighting.com

# ─── DELHIVERY ──────────────────────────────────────
DELHIVERY_API_KEY=your_delhivery_api_key
DELHIVERY_WAREHOUSE_NAME=Royce Lighting
DELHIVERY_BASE_URL=https://track.delhivery.com
# Use https://staging-express.delhivery.com for sandbox

# ─── APP URLS ───────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_WEB_URL=http://localhost:3332
NEXT_PUBLIC_ADMIN_URL=http://localhost:3002
NEXT_PUBLIC_VENDOR_URL=http://localhost:3003

# ─── API (NestJS) ───────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── UPLOADS ────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
